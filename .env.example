# =====================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =====================================================

# =====================================================
# NODE ENVIRONMENT
# =====================================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# =====================================================
# DATABASE (MongoDB)
# =====================================================
MONGO_ROOT_PASSWORD=change-this-secure-password-in-production

# =====================================================
# CACHE (Redis)
# =====================================================
REDIS_PASSWORD=change-this-redis-password-in-production

# =====================================================
# STORAGE (MinIO)
# =====================================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-this-minio-password-in-production

# =====================================================
# SECURITY
# =====================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-secure-random-jwt-secret-here
MASTER_KEY=generate-a-secure-encryption-key-here
MASTER_KEY_SALT=generate-a-secure-salt-here

# =====================================================
# EMAIL (Nodemailer - Gmail App Password)
# =====================================================
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password-from-gmail

# =====================================================
# MALWARE SCANNING
# =====================================================
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# =====================================================
# AI INTEGRATION (Ollama)
# =====================================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral:latest
AI_ENABLED=true
OLLAMA_TIMEOUT_MS=120000
AI_DETECT_ANOMALIES=true
AI_CLASSIFY_DOCUMENTS=true
AI_ANALYZE_MALWARE_BEHAVIOR=true
AI_DETECT_SUSPICIOUS_SHARING=true

# =====================================================
# TWO-FACTOR AUTHENTICATION (Twilio SMS)
# =====================================================
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# =====================================================
# RATE LIMITING
# =====================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
