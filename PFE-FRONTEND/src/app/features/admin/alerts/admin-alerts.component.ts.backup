        gap: 1rem;
      }

      .detail-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 1rem;
        align-items: center;
        padding: 0.95rem 1rem;
        border-radius: 0.95rem;
        background: #f8fbff;
      }

      .detail-row span {
        color: #475467;
      }

      .detail-row strong {
        color: #0f172a;
      }

      .detail-note {
        background: #eef2ff;
      }

      .detail-empty {
        padding: 3.5rem 1.5rem;
      }

      .error-banner {
        padding: 1rem 1.25rem;
        border-radius: 1rem;
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
      }

      .search-input {
        padding: 0.8rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 0.85rem;
        background: #fff;
        color: #101828;
        min-width: 260px;
        font-size: 0.95rem;
      }

      .search-input::placeholder {
        color: #9ca3af;
      }

      .score-bar {
        height: 0.35rem;
        background: #e5e7eb;
        border-radius: 999px;
        overflow: hidden;
        margin: 0.35rem 0 0;
      }

      .score-bar.full {
        height: 0.6rem;
      }

      .score-fill {
        height: 100%;
        border-radius: 999px;
        transition: width 280ms ease, background 280ms ease;
      }

      .score-fill.critical {
        background: linear-gradient(90deg, #dc2626, #991b1b);
      }

      .score-fill.high {
        background: linear-gradient(90deg, #ea580c, #c2410c);
      }

      .score-fill.medium {
        background: linear-gradient(90deg, #f59e0b, #d97706);
      }

      .score-fill.low {
        background: linear-gradient(90deg, #10b981, #059669);
      }

      .score-text {
        display: block;
        margin-top: 0.35rem;
        color: #64748b;
        font-size: 0.8rem;
      }

      .threat-score {
        display: grid;
        gap: 0.5rem;
        align-items: center;
        grid-template-columns: 1fr auto;
      }

      .threat-score strong {
        min-width: 3.5rem;
        text-align: right;
      }

      .pagination-controls {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 1.2rem;
        border-top: 1px solid rgba(219, 227, 243, 0.95);
        background: #f8fbff;
      }

      .pagination-controls button {
        border: 1px solid #d1d5db;
        border-radius: 0.75rem;
        padding: 0.65rem 1rem;
        background: white;
        color: #374151;
        cursor: pointer;
        font-weight: 600;
        transition: all 180ms ease;
      }

      .pagination-controls button:hover:not(:disabled) {
        background: #f3f4f6;
        border-color: #9ca3af;
      }

      .pagination-controls button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .pagination-controls span {
        color: #64748b;
        font-weight: 600;
      }

      .actions-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(219, 227, 243, 0.95);
      }

      .action-btn {
        border: none;
        border-radius: 0.95rem;
        padding: 0.95rem 1.25rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 200ms ease;
      }

      .action-btn.danger {
        background: linear-gradient(135deg, #dc2626, #991b1b);
        color: white;
        box-shadow: 0 10px 25px rgba(220, 38, 38, 0.2);
      }

      .action-btn.danger:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(220, 38, 38, 0.35);
      }

      .action-btn.success {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.2);
      }

      .action-btn.success:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(16, 185, 129, 0.35);
      }

      .action-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
      }

      @media (max-width: 1120px) {
        .alerts-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 680px) {
        .page-header,
        .status-strip,
        .alert-list-card,
        .alert-detail-card {
          padding: 1rem;
        }

        .status-strip {
          grid-template-columns: 1fr 1fr;
        }

        .header-actions {
          width: 100%;
          justify-content: stretch;
        }

        select {
          width: 100%;
        }
      }
    `
  ]
})
export class AdminAlertsComponent implements OnInit {
  private readonly adminApi = inject(AdminApiService);
  private readonly fileApi = inject(FileApiService);

  tenants: Tenant[] = [];
  selectedTenant = '';
  malwareAlerts: MalwareAlert[] = [];
  filteredAlerts: MalwareAlert[] = [];
  paginatedAlerts: MalwareAlert[] = [];
  selectedAlert: MalwareAlert | null = null;

  searchTerm = '';
  sortBy = 'newest';
  currentPage = 1;
  pageSize = 5;

  alertLoading = false;
  actionLoading = false;
  alertError = '';
  lastRefresh = '';

  ngOnInit(): void {
    this.loadTenants();
    this.refresh();
  }

  loadTenants(): void {
    this.adminApi.getTenantsList().subscribe({
      next: (tenants) => { this.tenants = tenants || []; },
      error: () => { this.tenants = []; }
    });
  }

  refresh(): void {
    this.alertLoading = true;
    this.alertError = '';
    this.adminApi.getMalwareAlerts({
      tenantId: this.selectedTenant || undefined,
      limit: 100
    }).subscribe({
      next: (response) => {
        this.malwareAlerts = response?.data || [];
        this.updateFilteredAlertsAfterRefresh();
        this.selectedAlert = this.malwareAlerts[0] || null;
        this.lastRefresh = new Date().toISOString();
        this.alertLoading = false;
      },
      error: (response) => {
        this.alertError = response?.error?.error || 'Impossible de charger les alertes de sécurité.';
        this.alertLoading = false;
      }
    });
  }

  updateFilteredAlertsAfterRefresh(): void {
    if (!this.searchTerm.trim()) {
      this.filteredAlerts = [...this.malwareAlerts];
    } else {
      const term = this.searchTerm.toLowerCase();
      this.filteredAlerts = this.malwareAlerts.filter((alert) =>
        alert.originalName?.toLowerCase().includes(term)
      );
    }
    // Vérifier si la page courante est encore valide après refresh
    if (this.currentPage > this.totalPages) {
      this.currentPage = this.totalPages;
    }
    this.updatePaginatedAlerts();
  }

  onTenantChange(): void {
    this.currentPage = 1;
    this.refresh();
  }

  selectAlert(alert: MalwareAlert): void {
    this.selectedAlert = alert;
  }

  updateFilteredAlerts(): void {
    // Remettre à la page 1 seulement lors d'une recherche
    this.currentPage = 1;
    if (!this.searchTerm.trim()) {
      this.filteredAlerts = [...this.malwareAlerts];
    } else {
      const term = this.searchTerm.toLowerCase();
      this.filteredAlerts = this.malwareAlerts.filter((alert) =>
        alert.originalName?.toLowerCase().includes(term)
      );
    }
    this.updatePaginatedAlerts();
  }

  get totalPages(): number {
    return Math.ceil(this.filteredAlerts.length / this.pageSize) || 1;
  }

  updatePaginatedAlerts(): void {
    const start = (this.currentPage - 1) * this.pageSize;
    const end = start + this.pageSize;
    this.paginatedAlerts = this.filteredAlerts.slice(start, end);
  }

  previousPage(): void {
    if (this.currentPage > 1) {
      this.currentPage--;
      this.updatePaginatedAlerts();
    }
  }

  nextPage(): void {
    if (this.currentPage < this.totalPages) {
      this.currentPage++;
      this.updatePaginatedAlerts();
    }
  }

  getThreatScore(alert: MalwareAlert): number {
    let score = 0;
    const meta = alert.scanMetadata;

    if (meta?.clamavResult?.isInfected) score += 40;
    if (meta?.virustotalResult?.isInfected) score += 35;
    if (String(meta?.quarantineStatus || '').toLowerCase() === 'quarantined') score += 20;
    if (alert.status === 'blocked') score += 5;

    return Math.min(score, 100);
  }

  getThreatSeverity(alert: MalwareAlert): string {
    const score = this.getThreatScore(alert);
    if (score >= 80) return 'critical';
    if (score >= 60) return 'high';
    if (score >= 40) return 'medium';
    return 'low';
  }

  toggleFileStatus(newStatus: 'blocked' | 'active'): void {
    if (!this.selectedAlert || this.actionLoading) return;

    this.actionLoading = true;
    this.fileApi.updateFileSettings(this.selectedAlert._id!, { status: newStatus }).subscribe({
      next: (updatedFile) => {
        // Recharger les données depuis le serveur pour refléter les changements
        this.refresh();
        this.actionLoading = false;
      },
      error: (err) => {
        console.error('Erreur lors de la mise à jour:', err);
        this.alertError = err?.error?.error || 'Erreur lors de la mise à jour du fichier.';
        this.actionLoading = false;
      }
    });
  }

  getOwnerDisplayName(file: MalwareAlert): string {
    const owner = file.ownerId;
    if (!owner) {
      return 'Propriétaire inconnu';
    }
    if (typeof owner === 'string') {
      return owner;
    }
    return owner.firstName || owner.email || owner.lastName || owner._id || 'Propriétaire inconnu';
  }

  trackByAlertId(index: number, alert: MalwareAlert): string {
    return alert._id || index.toString();
  }

  getAlertBadge(alert: MalwareAlert): string {
    if (String(alert?.scanMetadata?.quarantineStatus || '').toLowerCase() === 'quarantined') {
      return 'Quarantiné';
    }
    if (alert?.scanMetadata?.virustotalResult?.isInfected) {
      return 'VirusTotal';
    }
    if (alert?.scanMetadata?.clamavResult?.isInfected) {
      return 'ClamAV';
    }
    if (alert?.status === 'blocked') {
      return 'Bloqué';
    }
    return 'Suspect';
  }
  getTenantDisplayName(alert: MalwareAlert): string {
    const tenant = this.tenants.find((item) => item._id === alert.tenantId);
    return tenant?.name || alert.tenantId || 'Inconnu';
  }

  getRecipientCountLabel(alert: MalwareAlert): string {
    const sharedWith = (alert as unknown as { sharedWith?: Array<string | FileOwner> }).sharedWith;
    if (!Array.isArray(sharedWith) || sharedWith.length === 0) {
      return 'Aucun';
    }
    return `${sharedWith.length} destinataire(s)`;
  }

  openVirusTotal(hash: string): void {
    if (!hash) {
      return;
    }
    window.open(`https://www.virustotal.com/gui/file/${hash}`, '_blank');
  }
  getAlertStyle(alert: MalwareAlert): string {
    if (String(alert?.scanMetadata?.quarantineStatus || '').toLowerCase() === 'quarantined') {
      return 'danger';
    }
    if (alert?.scanMetadata?.clamavResult?.isInfected || alert?.scanMetadata?.virustotalResult?.isInfected) {
      return 'warning';
    }
    return 'success';
  }

  get alertCounts() {
    return {
      blocked: this.malwareAlerts.filter((alert) => alert.status === 'blocked').length,
      quarantined: this.malwareAlerts.filter((alert) => String(alert.scanMetadata?.quarantineStatus || '').toLowerCase() === 'quarantined').length,
      clamav: this.malwareAlerts.filter((alert) => !!alert.scanMetadata?.clamavResult?.isInfected).length,
      total: this.malwareAlerts.length
    };
  }

  formatDateTime(value: string | undefined): string {
    if (!value) return '-';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '-';
    return date.toLocaleString('fr-FR', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit'
    });
  }

  formatBytes(bytes: number): string {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return `${Math.round((bytes / Math.pow(k, i)) * 100) / 100} ${sizes[i]}`;
  }

  downloadFile(alert: MalwareAlert): void {
    if (!alert || this.actionLoading) return;

    this.actionLoading = true;
    this.fileApi.downloadFile(alert._id!).subscribe({
      next: (blob) => {
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = alert.originalName || 'file';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
        this.actionLoading = false;
      },
      error: (err) => {
        console.error('Erreur lors du téléchargement:', err);
        this.alertError = err?.error?.error || 'Erreur lors du téléchargement du fichier.';
        this.actionLoading = false;
      }
    });
  }

  manageQuarantine(alert: MalwareAlert, action: string): void {
    if (!alert || this.actionLoading) return;

    this.actionLoading = true;
    // Call the backend API to manage quarantine
    this.adminApi.manageQuarantinedFile(alert._id!, action).subscribe({
      next: (result) => {
        // Refresh the alerts to show updated status
        this.refresh();
        this.actionLoading = false;
      },
      error: (err) => {
        console.error('Erreur lors de la gestion de quarantaine:', err);
        this.alertError = err?.error?.error || 'Erreur lors de la gestion de quarantaine.';
        this.actionLoading = false;
      }
    });
  }

  deleteFile(alert: MalwareAlert): void {
    if (!alert || this.actionLoading) return;

    if (!confirm(`Êtes-vous sûr de vouloir supprimer définitivement le fichier "${alert.originalName}" ?`)) {
      return;
    }

    this.actionLoading = true;
    this.fileApi.deleteFile(alert._id!).subscribe({
      next: () => {
        // Refresh the alerts to remove the deleted file
        this.refresh();
        this.actionLoading = false;
      },
      error: (err) => {
        console.error('Erreur lors de la suppression:', err);
        this.alertError = err?.error?.error || 'Erreur lors de la suppression du fichier.';
        this.actionLoading = false;
      }
    });
  }
}
