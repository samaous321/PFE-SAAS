      }

      .alert-summary strong {
        display: block;
        color: #0f172a;
      }

      .owner {
        margin: 0.35rem 0 0;
        color: #64748b;
        font-size: 0.92rem;
      }

      .tag {
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      .tag.danger {
        background: #fee2e2;
        color: #b91c1c;
      }

      .tag.warning {
        background: #fef3c7;
        color: #92400e;
      }

      .tag.success {
        background: #d1fae5;
        color: #047857;
      }

      .alert-meta {
        margin-top: 0.85rem;
        display: flex;
        justify-content: space-between;
        color: #64748b;
        font-size: 0.86rem;
      }

      .detail-header {
        align-items: center;
