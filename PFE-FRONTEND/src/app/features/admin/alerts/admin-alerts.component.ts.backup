      }

      .alert-list {
        display: grid;
        gap: 0.85rem;
        padding: 1rem 1.2rem 1.25rem;
      }

      .alert-card {
        width: 100%;
        border: 1px solid transparent;
        border-radius: 1rem;
        background: #f8fbff;
        padding: 1rem 1.25rem;
        text-align: left;
        cursor: pointer;
        transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
      }

      .alert-card:hover,
      .alert-card.selected {
        background: #eff5ff;
        border-color: #b9d4ff;
        transform: translateY(-1px);
      }

      .alert-summary {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
