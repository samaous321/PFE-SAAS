        </ng-template>
      </div>
    </div>

      <!-- Shared By Me Section -->
      <div class="files-section" *ngIf="!loading && activeTab === 'shared-by-me'">
        <div class="files-header">
          <h3>Fichiers partagÃ©s par vous</h3>
          <div class="files-count">{{ sharedByMe.length }} partage{{ sharedByMe.length > 1 ? "s" : "" }}</div>
        </div>

        <div class="list-controls compact" *ngIf="showAdvancedFilters">
          <label>
            Trier
            <select [value]="sharedByMeSortBy" (change)="onSharedByMeSortChange($event)">
              <option value="date_desc">Date (plus rÃ©cent)</option>
              <option value="date_asc">Date (plus ancien)</option>
              <option value="name_asc">Nom (A-Z)</option>
              <option value="name_desc">Nom (Z-A)</option>
            </select>
          </label>

          <label>
            Par page
            <select [value]="sharedByMePageSize" (change)="onSharedByMePageSizeChange($event)">
              <option [value]="4">4</option>
              <option [value]="6">6</option>
              <option [value]="10">10</option>
            </select>
          </label>
        </div>

        <div class="shared-by-me-grid" *ngIf="sharedByMe.length > 0; else noSharedByMe">
          <div class="shared-by-me-card" *ngFor="let shared of sharedByMe">
            <div class="shared-card-header">
              <div class="file-info">
                <span class="file-icon">{{ getFileIcon(shared.file) }}</span>
                <div class="file-details">
                  <h4>{{ shared.file.originalName }}</h4>
                  <div class="file-meta">
                    <span class="file-size">{{ formatBytes(shared.file.size || 0) }}</span>
                    <span class="file-date">PartagÃ© le {{ shared.createdAt ? formatDate(shared.createdAt) : 'Date inconnue' }}</span>
                  </div>
                </div>
              </div>
              <div class="share-status">
                <span class="status-badge" [class]="'status-' + getShareStatus(shared)">
                  {{ getShareStatusText(shared) }}
                </span>
              </div>
            </div>

            <div class="share-details">
              <div class="share-info-row">
                <div class="share-info-item">
                  <span class="info-label">Destinataires:</span>
                  <span class="info-value">
                    <span *ngIf="shared.recipientUsers && shared.recipientUsers.length > 0">
                      {{ getRecipientNames(shared) }}
                    </span>
                    <span *ngIf="(!shared.recipientUsers || shared.recipientUsers.length === 0) && shared.recipientEmail">
                      {{ shared.recipientEmail }}
                    </span>
                    <span *ngIf="(!shared.recipientUsers || shared.recipientUsers.length === 0) && !shared.recipientEmail">
                      Lien public
                    </span>
                  </span>
                </div>
                <div class="share-info-item">
                  <span class="info-label">Expiration:</span>
                  <span class="info-value">{{ formatDate(shared.expiresAt) }}</span>
                </div>
              </div>

              <div class="share-info-row">
                <div class="share-info-item">
                  <span class="info-label">Utilisations:</span>
                  <span class="info-value">{{ shared.usedCount || 0 }} / {{ shared.maxUses }}</span>
                </div>
                <div class="share-info-item">
                  <span class="info-label">TÃ©lÃ©chargements:</span>
                  <span class="info-value">{{ getDownloadCount(shared) }}</span>
                </div>
              </div>

              <div class="share-actions">
                <button class="btn btn-sm btn-outline" type="button" (click)="copyShareLink(shared)" *ngIf="shared.shareUrl">
                  ðŸ“‹ Copier lien
                </button>
                <button class="btn btn-sm btn-outline" type="button" (click)="viewShareDetails(shared)">
                  ðŸ‘ï¸ DÃ©tails
                </button>
                <button class="btn btn-sm btn-danger" type="button" (click)="revokeShare(shared)">
                  ðŸš« Annuler partage
                </button>
              </div>
            </div>
          </div>
        </div>

        <ng-template #noSharedByMe>
          <div class="empty-state">
            <div class="empty-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <h4>Aucun partage actif</h4>
            <p>Les fichiers que vous partagez apparaÃ®tront ici</p>
          </div>
        </ng-template>
      </div>
    </div>
  </div>
      <div class="share-modal-backdrop" *ngIf="showShareModal" (click)="closeShareModal()">
        <div class="share-modal modern-share-modal" (click)="$event.stopPropagation()">
          <div class="modal-header">
            <div>
              <h3>ðŸ“¤ Partager le fichier</h3>
              <p class="modal-subtitle">{{ selectedFileForShare?.originalName }}</p>
            </div>
            <button class="modal-close" (click)="closeShareModal()" type="button">Ã—</button>

          <form [formGroup]="shareForm" (ngSubmit)="createShareLink()" class="share-form">
            
            <!-- Row 1: Mode + Expiration -->
            <div class="form-row row-primary">
              <div class="form-group">
                <label>Mode</label>
                <select formControlName="shareMode" required>
                  <option value="link">ðŸŒ Lien public</option>
                  <option value="direct">ðŸ”’ Utilisateur(s)</option>
                </select>
              </div>

              <div class="form-group">
                <label>Expiration</label>
                <div class="input-with-unit">
                  <input type="number" formControlName="expiresInHours" min="1" max="168" placeholder="48" required>
                  <span class="unit">h</span>
                </div>
              </div>

              <div class="form-group">
                <label>Max tÃ©lÃ©chargements</label>
                <div class="input-with-unit">
                  <input type="number" formControlName="maxUses" min="1" max="100" placeholder="10" required>
                  <span class="unit">Ã—</span>
                </div>
              </div>
            </div>

            <!-- Row 2: Recipients (Direct mode) -->
            <div class="form-row row-secondary" *ngIf="shareForm.get('shareMode')?.value === 'direct'">
              <div class="form-group full-width">
                <div class="field-head field-head-row">
                  <div>
                    <label>Destinataires</label>
                    <span class="field-hint">Clique sur un chip pour sÃ©lectionner ou retirer un utilisateur</span>
                  </div>

                  <div class="selection-badge" *ngIf="filteredTenantUsers.length">
                    {{ shareForm.get('recipientUserIds')?.value?.length || 0 }} sÃ©lectionnÃ©(s) / {{ filteredTenantUsers.length }}
                  </div>
                </div>

                <div class="recipient-search">
                  <input
                    type="text"
                    [value]="recipientSearch"
                    (input)="recipientSearch = $any($event.target).value"
                    placeholder="Rechercher un utilisateur..."
                  >
                </div>

                <div class="recipient-chips">
                  <button
                    type="button"
                    class="recipient-chip"
                    *ngFor="let user of filteredTenantUsers"
                    [class.selected]="isRecipientSelected(user._id)"
                    (click)="toggleRecipient(user._id)"
                  >
                    <span class="chip-avatar">{{ user.firstName.charAt(0) }}{{ user.lastName.charAt(0) }}</span>
                    <span class="chip-text">
                      <strong>{{ user.firstName }} {{ user.lastName }}</strong>
                      <small>{{ user.email }}</small>
                    </span>
                  </button>
                </div>

                <div class="selected-recipients" *ngIf="shareForm.get('recipientUserIds')?.value?.length">
                  {{ shareForm.get('recipientUserIds')?.value?.length }} destinataire(s) sÃ©lectionnÃ©(s)
                </div>
              </div>
            </div>

            <!-- Row 3: Subject + Description -->
            <div class="form-row row-secondary share-details-row" *ngIf="shareForm.get('shareMode')?.value === 'direct'">
              <div class="form-group share-subject-col">
                <label>Objet du partage (optionnel)</label>
                <input type="text" formControlName="shareSubject" placeholder="Ex: RÃ©vision projet Q2">
              </div>

              <div class="form-group share-description-col">
                <label>Description (optionnel)</label>
                <textarea formControlName="shareDescription" rows="2" placeholder="Ajouter des dÃ©tails..."></textarea>
              </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
              <button type="button" class="btn btn-secondary" (click)="closeShareModal()">Annuler</button>
              <button type="submit" class="btn btn-primary" [disabled]="busy">
                <span *ngIf="!busy">{{ shareForm.get("shareMode")?.value === "direct" ? "ðŸ“¤ Partager" : "ðŸ”— CrÃ©er lien" }}</span>
                <span *ngIf="busy">â³ CrÃ©ation...</span>
              </button>
            </div>
          </form>
        </div>
      </div>

      <div class="share-modal-backdrop" *ngIf="publicShareResult" (click)="closePublicSharePopup()">
        <div class="share-modal modern-share-modal" (click)="$event.stopPropagation()">
          <div class="modal-header">
            <div>
              <h3>ðŸ”— Lien public crÃ©Ã©</h3>
              <p class="modal-subtitle">Partage prÃªt. Copiez rapidement le lien.</p>
            </div>
            <button class="modal-close" (click)="closePublicSharePopup()" type="button">Ã—</button>
          </div>

          <div class="share-form">
            <div class="public-link-box">
              <label>Lien de tÃ©lÃ©chargement</label>
              <input
                type="text"
                [value]="publicShareResult?.shareUrl || ''"
                readonly
                (focus)="$any($event.target).select()"
              >
            </div>

            <div class="form-actions">
              <button type="button" class="btn btn-secondary" (click)="closePublicSharePopup()">Fermer</button>
              <button type="button" class="btn btn-primary" (click)="copyPublicShareLink()">
                {{ publicShareResult?.copied ? "âœ… CopiÃ©" : "ðŸ“‹ Copier le lien" }}
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="scan-modal-backdrop" *ngIf="scanResult" (click)="closeScanModal()">
        <div class="share-modal modern-share-modal scan-modal" (click)="$event.stopPropagation()">
          <div class="modal-header">
            <div>
              <h3>{{ scanResult.isInfected ? "âš ï¸ RÃ©sultat de l'analyse" : "âœ… RÃ©sultat de l'analyse" }}</h3>
              <p class="modal-subtitle">{{ scanResult.originalName }}</p>
            </div>
            <button class="modal-close" (click)="closeScanModal()" type="button">Ã—</button>
          </div>

          <div class="share-form scan-result-panel">
            <div class="scan-summary">
              <div class="scan-line">
                <span>Statut</span>
                <strong>{{ scanResult.isInfected ? "InfectÃ©" : "Propre" }}</strong>
              </div>
              <div class="scan-line" *ngIf="scanResult.fileHash">
                <span>Hash SHA-256</span>
                <strong>{{ scanResult.fileHash }}</strong>
              </div>
              <div class="scan-line" *ngIf="scanResult.warning">
                <span>Alerte</span>
                <strong>{{ scanResult.warning }}</strong>
              </div>
            </div>

            <div class="scan-details">
              <div class="detail-block">
                <h4>ClamAV</h4>
                <p>{{ scanResult.clamavResult?.isInfected ? "Menace dÃ©tectÃ©e" : "Aucun virus dÃ©tectÃ©" }}</p>
                <p *ngIf="scanResult.clamavResult?.viruses?.length">Moteurs dÃ©tecteurs: {{ scanResult.clamavResult?.viruses?.join(', ') }}</p>
                <p *ngIf="scanResult.clamavResult?.warning">{{ scanResult.clamavResult?.warning }}</p>
              </div>

              <div class="detail-block" *ngIf="scanResult.virustotalResult">
                <h4>VirusTotal</h4>
                <p>{{ scanResult.virustotalResult.isInfected ? "Menace dÃ©tectÃ©e" : "Aucun virus dÃ©tectÃ©" }}</p>
                <p *ngIf="scanResult.virustotalResult.detectionRatio">Ratio: {{ scanResult.virustotalResult.detectionRatio }}</p>
                <p *ngIf="scanResult.virustotalResult.warning">{{ scanResult.virustotalResult.warning }}</p>
              </div>
            </div>

            <div class="form-actions">
              <button type="button" class="btn btn-secondary" (click)="closeScanModal()">Fermer</button>
              <button *ngIf="!scanResult.isInfected" type="button" class="btn btn-primary" (click)="downloadFromScanModal()">
                TÃ©lÃ©charger
              </button>
              <button *ngIf="scanResult.virustotalUrl" type="button" class="btn btn-neutral" (click)="openExternalUrl(scanResult.virustotalUrl)">
                Voir sur VirusTotal
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

  