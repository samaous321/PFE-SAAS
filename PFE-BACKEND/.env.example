# Copy this file to .env and fill values for local development.
# Sensitive values should NOT be committed.

PORT=3000
MONGO_URI=mongodb://localhost:27017/secure_saas
JWT_SECRET=change_me
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
MASTER_KEY=replace_with_secure_master_key
NODE_ENV=development
APP_URL=http://localhost:3000
VIRUSTOTAL_API_KEY=your_virustotal_key
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
UPLOAD_DIR=uploads
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:latest
AI_ENABLED=true
OLLAMA_TIMEOUT_MS=120000
AI_SUSPICIOUS_SHARING_THRESHOLD=75
AI_ANOMALY_CONFIDENCE_THRESHOLD=70# =====================================================
# ENVIRONMENT VARIABLES - COPY TO .env
# =====================================================
# ⚠️ IMPORTANT: Never commit .env to git
# ✅ Add .env to .gitignore

# Node Environment
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# =====================================================
# DATABASE
# =====================================================
MONGO_URI=mongodb://localhost:27017/pfe_backend
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# =====================================================
# AUTHENTICATION
# =====================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-256-bit-jwt-secret-minimum-32-characters-change-this-in-production

# Token expiration (in milliseconds)
JWT_EXPIRATION=3600000  # 1 hour

# =====================================================
# ENCRYPTION (CRITICAL - NEVER LOSE THIS)
# =====================================================
# Generate with: openssl rand -hex 32
# This is your master key for file encryption - BACKUP IT!
MASTER_KEY=your-64-character-hex-key-openssl-rand-hex-32-then-double-it

# Salt for PBKDF2 key derivation (can be constant)
MASTER_KEY_SALT=production-salt-change-this-value

# =====================================================
# EMAIL (Nodemailer)
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@pfe-backend.example.com

# For Gmail: Use App Password
# https://myaccount.google.com/apppasswords

# =====================================================
# TWO-FACTOR AUTHENTICATION (OTP via SMS)
# =====================================================
# Twilio Configuration for SMS OTP delivery
# Get credentials from: https://www.twilio.com/console
# 1. Create Twilio account
# 2. Get Account SID and Auth Token
# 3. Purchase a phone number or use trial number

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Tunisian phone number format: +216xxxxxxxx
# Example: +21698123456
# Note: Ensure your Twilio account supports Tunisian numbers (+216)

# =====================================================
# MALWARE SCANNING (VirusTotal)
# =====================================================
# Get free API key: https://www.virustotal.com/gui/my-apikey
# Free tier: 4 requests/minute, 500 requests/day
# Paid: Higher limits available
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ClamAV local scanner (daemon)
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# VT queue storage (Bull requires Redis)
REDIS_URL=redis://localhost:6379

# =====================================================
# CLOUD STORAGE
# =====================================================
# Options: "minio" | "s3" | "local"
STORAGE_PROVIDER=local

# MinIO Configuration (for self-hosted S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1

# AWS S3 Configuration (for AWS cloud storage)
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Upload directory (for local storage provider)
UPLOAD_DIR=uploads

# =====================================================
# SECURITY
# =====================================================
# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# =====================================================
# LOGGING
# =====================================================
LOG_LEVEL=info
# Options: "error" | "warn" | "info" | "debug" | "trace"

# =====================================================
# DEVELOPMENT/TESTING
# =====================================================
DEBUG=pfe:*
SKIP_AUTH_FOR_TESTING=false  # ONLY for testing!

# =====================================================
# 🔒 PRODUCTION CHECKLIST
# =====================================================
# Before deploying to production:
# 
# [ ] Generate new JWT_SECRET (openssl rand -hex 32)
# [ ] Generate new MASTER_KEY (openssl rand -hex 32)
# [ ] Set NODE_ENV=production
# [ ] Configure HTTPS/TLS certificate
# [ ] Set real MONGO_URI (MongoDB Atlas or self-hosted)
# [ ] Configure real SMTP (SendGrid, AWS SES, etc.)
# [ ] Get VirusTotal API key for production
# [ ] Configure MinIO or AWS S3
# [ ] Set strong CORS_ORIGINS
# [ ] Enable rate limiting
# [ ] Store .env in secure location (not git, use secrets manager)
# [ ] Test all endpoints with real data
# [ ] Enable audit logging
# [ ] Configure backups
# [ ] Run security audit
